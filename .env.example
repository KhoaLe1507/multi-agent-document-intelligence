# 1. Local dataset
DATA_DIR=data
DATA_DUMP_PATH=data/dump.json
LOCAL_SUBMISSIONS_PATH=logs/local_submissions.jsonl
LOCAL_SKIP_MISSING_TASKS=true

# 2. Gemini API
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"
GEMINI_MODEL_NAME=gemini-2.5-flash

# 3. Model/token settings
MAX_TOKENS_PER_CHUNK=4000
MAX_RETRIES=3

# 4. Agent temperatures
TEMP_ROUTER=0.0
TEMP_EXTRACTOR=0.1
TEMP_SYNTHESIZER=0.3
